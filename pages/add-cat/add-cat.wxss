/* 添加猫咪页样式 */
.form-container {
  padding: 20rpx 30rpx 200rpx;
}

.photo-upload {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  margin: 30rpx auto;
  overflow: hidden;
  background: #FFF2E6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #FFB380;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.photo-icon {
  font-size: 48rpx;
}

.photo-text {
  font-size: 24rpx;
  color: #FFB380;
}

.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F8F0E8;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.column {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  font-size: 28rpx;
  color: #2D2D2D;
  flex-shrink: 0;
}

.form-input {
  text-align: right;
  font-size: 28rpx;
  flex: 1;
  margin-left: 20rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.gender-options {
  display: flex;
  gap: 16rpx;
}

.gender-opt {
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  background: #F5F5F5;
  color: #666;
}

.gender-opt.active {
  background: #FFF2E6;
  color: #FF8C42;
  border: 1rpx solid #FF8C42;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.05);
}
