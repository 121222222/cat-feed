/* 个人中心样式 */
.profile-header {
  position: relative;
  padding-bottom: 20rpx;
}

.profile-bg {
  height: 300rpx;
  background: linear-gradient(135deg, #FF8C42, #FF6B42, #FFB380);
  border-radius: 0 0 50rpx 50rpx;
}

.profile-info {
  margin-top: -120rpx;
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar-wrap {
  position: relative;
  margin-bottom: 16rpx;
}

.avatar-xl {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  overflow: hidden;
  background: #FFF2E6;
}

.avatar-xl image {
  width: 100%;
  height: 100%;
}

.certified-icon {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #52C41A;
  color: #FFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFF;
}

.profile-detail {
  text-align: center;
  width: 100%;
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.certified-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #F0FFF0;
  color: #52C41A;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.profile-dorm {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.profile-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF8C42;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: #F0E0D0;
}

/* 猫咪卡片 */
.section {
  padding: 0 30rpx;
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.section-more {
  font-size: 24rpx;
  color: #FF8C42;
}

.cat-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.cat-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-right: 16rpx;
  width: 180rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.cat-card-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #FFF2E6;
  margin-bottom: 10rpx;
}

.cat-card-avatar image {
  width: 100%;
  height: 100%;
}

.cat-card-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.cat-card-info {
  font-size: 20rpx;
  color: #999;
}

.add-cat {
  background: #FFF8F0;
  border: 2rpx dashed #FFB380;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #FFB380;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #FFB380;
}

/* 菜单组 */
.menu-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F8F0E8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon {
  font-size: 28rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D2D2D;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

.menu-badge-success {
  font-size: 22rpx;
  color: #52C41A;
}

.menu-badge-warn {
  font-size: 22rpx;
  color: #FAAD14;
}
