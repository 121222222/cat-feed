/* 可接单列表页样式 */
.filter-bar {
  display: flex;
  background: #FFFFFF;
  padding: 16rpx 30rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #F5EDE5;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 50rpx;
  background: #F5F5F5;
  font-size: 24rpx;
  color: #666;
}

.filter-arrow {
  font-size: 18rpx;
  color: #999;
}

.list-container {
  padding: 20rpx 30rpx;
}

.need-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.need-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.need-user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.need-user-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.need-user-dorm {
  display: block;
  font-size: 20rpx;
  color: #999;
}

.need-reward {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF8C42;
}

.need-content {
  margin-bottom: 12rpx;
}

.need-cat-row {
  display: flex;
  gap: 16rpx;
}

.cat-mini-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFF2E6;
  flex-shrink: 0;
}

.cat-mini-avatar image {
  width: 100%;
  height: 100%;
}

.need-cat-detail {
  flex: 1;
}

.cat-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.cat-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.need-meta-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.need-service-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.service-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #FFF2E6;
  color: #FF8C42;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.need-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5EDE5;
}

.need-time {
  font-size: 22rpx;
  color: #CCC;
}
