/* 喂养人详情页样式 */
.feeder-header {
  position: relative;
}

.feeder-bg {
  height: 280rpx;
  background: linear-gradient(135deg, #FFB380, #FF8C42);
  border-radius: 0 0 50rpx 50rpx;
}

.feeder-info-wrap {
  margin-top: -100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 20rpx;
}

.feeder-avatar-big {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #FFF;
  background: #FFF2E6;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.feeder-avatar-big image {
  width: 100%;
  height: 100%;
}

.cert-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #52C41A;
  color: #FFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFF;
}

.feeder-name-big {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-top: 16rpx;
}

.feeder-dorm-big {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  margin-bottom: 20rpx;
}

.feeder-stats {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
  width: calc(100% - 60rpx);
  margin: 0 30rpx;
  box-sizing: border-box;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF8C42;
  margin-bottom: 6rpx;
}

.stat-lbl {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: #F0E0D0;
}

/* 详情卡片 */
.detail-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F5EDE5;
}

.card-content {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
}

/* 评价 */
.review-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F8F0E8;
}

.review-item:last-child {
  border-bottom: none;
}

.review-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.review-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.review-stars {
  display: flex;
  gap: 2rpx;
}

.star {
  font-size: 20rpx;
}

.review-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 6rpx;
}

.review-time {
  display: block;
  font-size: 22rpx;
  color: #BBB;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}
