/* 需求详情页样式 */
.cat-hero {
  position: relative;
  padding-bottom: 30rpx;
}

.cat-hero-bg {
  height: 280rpx;
  background: linear-gradient(135deg, #FFB380, #FF8C42);
  border-radius: 0 0 50rpx 50rpx;
}

.cat-hero-content {
  margin-top: -100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cat-big-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: #FFF2E6;
  border: 6rpx solid #FFF;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.cat-big-avatar image {
  width: 100%;
  height: 100%;
}

.cat-hero-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-top: 16rpx;
}

.cat-hero-info {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.status-badge-lg {
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.reward-lg {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF8C42;
}

/* 详情卡片 */
.detail-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F5EDE5;
}

.detail-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
}

.detail-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #2D2D2D;
}

.service-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.service-tag {
  padding: 10rpx 24rpx;
  background: #FFF2E6;
  color: #FF8C42;
  font-size: 24rpx;
  border-radius: 50rpx;
}

/* 用户信息 */
.user-info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-info-detail {
  flex: 1;
}

.user-info-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.user-info-dorm {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}

/* 状态颜色 */
.status-pending { background: #FFFBE6; color: #FAAD14; }
.status-accepted { background: #E6F7FF; color: #1890FF; }
.status-in_progress { background: #F0FFF0; color: #52C41A; }
.status-completed { background: #F5F5F5; color: #999; }
.status-cancelled { background: #FFF2F0; color: #FF4D4F; }
