/* 打卡页样式 */
.checkin-content {
  padding: 20rpx 30rpx 200rpx;
}

.checkin-status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.checkin-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8C42, #FF6B42);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 140, 66, 0.3);
  margin-bottom: 20rpx;
}

.checkin-circle.checked {
  background: linear-gradient(135deg, #52C41A, #73D13D);
  box-shadow: 0 8rpx 30rpx rgba(82, 196, 26, 0.3);
}

.checkin-icon {
  font-size: 60rpx;
}

.checkin-text {
  font-size: 24rpx;
  color: #FFFFFF;
  margin-top: 6rpx;
}

.checkin-time {
  font-size: 26rpx;
  color: #52C41A;
  font-weight: 600;
}

.checkin-hint {
  font-size: 24rpx;
  color: #999;
}

.task-card, .photo-card, .note-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.task-title, .photo-title, .note-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #FFF8F0;
}

.task-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #DDD;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #FFF;
}

.task-check.done {
  background: #52C41A;
  border-color: #52C41A;
}

.task-name {
  font-size: 28rpx;
  color: #2D2D2D;
}

.task-name.task-done {
  color: #999;
  text-decoration: line-through;
}

.photo-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #FFB380;
  background: #FFF8F0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-add-icon {
  font-size: 44rpx;
  color: #FFB380;
  line-height: 1;
}

.photo-add-text {
  font-size: 20rpx;
  color: #FFB380;
  margin-top: 6rpx;
}

.note-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}
