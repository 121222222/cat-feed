/* 聊天页样式 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFF8F0;
}

.chat-messages {
  flex: 1;
  padding: 20rpx 30rpx;
  padding-bottom: 140rpx;
}

.msg-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.msg-item.mine {
  justify-content: flex-end;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #FFF2E6;
  flex-shrink: 0;
}

.msg-avatar image {
  width: 100%;
  height: 100%;
}

.msg-bubble {
  max-width: 70%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.bubble-other {
  background: #FFFFFF;
  color: #2D2D2D;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.bubble-mine {
  background: linear-gradient(135deg, #FF8C42, #FF6B42);
  color: #FFFFFF;
  border-top-right-radius: 6rpx;
}

.msg-text {
  font-size: 28rpx;
}

/* 输入栏 */
.chat-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}

.chat-input {
  flex: 1;
  padding: 18rpx 24rpx;
  background: #F5F5F5;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  background: #E0E0E0;
  color: #999;
}

.send-btn.active {
  background: linear-gradient(135deg, #FF8C42, #FF6B42);
  color: #FFFFFF;
}
