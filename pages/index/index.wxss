/* 首页样式 */
.header {
  width: 100%;
}

.header-bg {
  background: linear-gradient(135deg, #FF8C42, #FF6B42, #FFB380);
  padding: 30rpx 30rpx 60rpx;
  border-radius: 0 0 50rpx 50rpx;
}

.header-content {
  padding-top: 10rpx;
}

.greeting {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.greeting-emoji {
  font-size: 60rpx;
}

.greeting-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.greeting-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

.search-wrap {
  margin-top: 10rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border-radius: 50rpx;
  padding: 18rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  color: #BBBBBB;
  font-size: 26rpx;
}

/* 快捷入口 - 大面积醒目设计 */
.quick-entry {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: -40rpx;
}

.entry-card {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 66, 0.18);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.entry-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 66, 0.12);
}

.entry-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.entry-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  flex-shrink: 0;
}

.need-circle {
  background: linear-gradient(135deg, #FFF2E6, #FFE0C4);
}

.feed-circle {
  background: linear-gradient(135deg, #FFF8E6, #FFE8B0);
}

.entry-need {
  border-left: 8rpx solid #FF8C42;
}

.entry-feed {
  border-left: 8rpx solid #FFB347;
}

.entry-info {
  flex: 1;
}

.entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.entry-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.entry-arrow-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFF2E6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.entry-arrow {
  font-size: 32rpx;
  color: #FF8C42;
  font-weight: 700;
}

/* 公告栏 */
.notice-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(90deg, #FFF8F0, #FFF2E6);
  margin: 24rpx 30rpx 0;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #FFE4C4;
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #666;
  line-height: 40rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.notice-more {
  font-size: 22rpx;
  color: #FF8C42;
  margin-left: 12rpx;
}

/* 区块 */
.section {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.section-more {
  font-size: 24rpx;
  color: #FF8C42;
}

/* 需求卡片 */
.need-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.need-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.need-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.need-username {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.need-time {
  font-size: 20rpx;
  color: #BBB;
}

.need-status {
  font-size: 22rpx;
}

.need-body {
  margin-bottom: 16rpx;
}

.need-cat-info {
  display: flex;
  gap: 16rpx;
}

.cat-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFF2E6;
  flex-shrink: 0;
}

.cat-avatar image {
  width: 100%;
  height: 100%;
}

.need-detail {
  flex: 1;
}

.need-cat-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.need-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.need-footer {
  border-top: 1rpx solid #F5EDE5;
  padding-top: 16rpx;
}

.need-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.mini-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #FFF2E6;
  color: #FF8C42;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.need-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.need-date {
  font-size: 22rpx;
  color: #999;
}

.need-reward {
  font-size: 24rpx;
  font-weight: 600;
}

.need-dorm {
  font-size: 22rpx;
  color: #999;
}

/* 喂养人横向滚动 */
.feeder-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.feeder-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-right: 20rpx;
  width: 220rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
}

.feeder-avatar-wrap {
  position: relative;
  margin-bottom: 12rpx;
}

.certified-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #52C41A;
  color: #FFF;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FFF;
}

.feeder-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.feeder-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 4rpx;
}

.rating-num {
  font-size: 22rpx;
  color: #FF8C42;
  font-weight: 600;
}

.feeder-count {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.feeder-dorm {
  font-size: 20rpx;
  color: #BBB;
}
