<view class="page-container">
  <!-- 顶部渐变头部 -->
  <view class="header">
    <view class="header-bg">
      <view class="header-content">
        <view class="greeting">
          <text class="greeting-emoji">🐱</text>
          <view>
            <text class="greeting-text">Hi，{{userInfo.name}}</text>
            <text class="greeting-sub">今天也要好好照顾喵星人哦~</text>
          </view>
        </view>
      </view>
      <!-- 搜索栏 -->
      <view class="search-wrap">
        <view class="search-box" bindtap="onSearchTap">
          <text class="search-icon">🔍</text>
          <text class="search-placeholder">搜索喂养需求 / 喂养人</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-card entry-need" bindtap="goPublish">
      <view class="entry-left">
        <view class="entry-icon-circle need-circle">🙋</view>
        <view class="entry-info">
          <text class="entry-title">找鹅喂猫</text>
          <text class="entry-desc">一键发布喂养需求</text>
        </view>
      </view>
      <view class="entry-arrow-circle">
        <text class="entry-arrow">›</text>
      </view>
    </view>
    <view class="entry-card entry-feed" bindtap="goAcceptList">
      <view class="entry-left">
        <view class="entry-icon-circle feed-circle">🐾</view>
        <view class="entry-info">
          <text class="entry-title">鹅要上门</text>
          <text class="entry-desc">一键接单帮忙喂猫</text>
        </view>
      </view>
      <view class="entry-arrow-circle">
        <text class="entry-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 公告栏 -->
  <view class="notice-bar" bindtap="goNotice">
    <text class="notice-icon">📢</text>
    <swiper class="notice-swiper" vertical autoplay circular interval="3000" duration="500">
      <swiper-item wx:for="{{notices}}" wx:key="index">
        <text class="notice-text">{{item}}</text>
      </swiper-item>
    </swiper>
    <text class="notice-more">查看</text>
  </view>

  <!-- 最新喂养需求 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <text class="section-icon">📋</text>
        <text class="section-title">最新喂养需求</text>
      </view>
      <text class="section-more" bindtap="goMoreNeeds">更多 ›</text>
    </view>
    <view class="need-list">
      <view class="need-card" wx:for="{{needs}}" wx:key="id" bindtap="goNeedDetail" data-id="{{item.id}}">
        <view class="need-top">
          <view class="need-user">
            <view class="avatar avatar-sm">
              <image src="{{item.userAvatar}}" mode="aspectFill"></image>
            </view>
            <text class="need-username">{{item.userName}}</text>
            <text class="need-time">{{item.createTime}}</text>
          </view>
          <view class="need-status tag tag-{{item.status === 'pending' ? 'warning' : 'info'}}">
            {{item.status === 'pending' ? '待接单' : '已接单'}}
          </view>
        </view>
        <view class="need-body">
          <view class="need-cat-info">
            <view class="cat-avatar">
              <image src="{{item.catAvatar}}" mode="aspectFill"></image>
            </view>
            <view class="need-detail">
              <text class="need-cat-name">🐱 {{item.catName}} · {{item.catCount}}只</text>
              <text class="need-desc">{{item.description}}</text>
            </view>
          </view>
        </view>
        <view class="need-footer">
          <view class="need-tags">
            <text class="mini-tag" wx:for="{{item.services}}" wx:for-item="service" wx:key="*this">{{service}}</text>
          </view>
          <view class="need-meta">
            <text class="need-date">📅 {{item.startDate}} ~ {{item.endDate}}</text>
            <text class="need-reward text-primary">💰 {{item.reward}}</text>
          </view>
          <text class="need-dorm">📍 {{item.dormitory}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 推荐喂养人 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <text class="section-icon">⭐</text>
        <text class="section-title">推荐喂养人</text>
      </view>
      <text class="section-more" bindtap="goMoreFeeders">更多 ›</text>
    </view>
    <scroll-view scroll-x class="feeder-scroll">
      <view class="feeder-card" wx:for="{{feeders}}" wx:key="id" bindtap="goFeederDetail" data-id="{{item.id}}">
        <view class="feeder-avatar-wrap">
          <view class="avatar avatar-lg">
            <image src="{{item.avatar}}" mode="aspectFill"></image>
          </view>
          <view class="certified-badge" wx:if="{{item.certified}}">✓</view>
        </view>
        <text class="feeder-name">{{item.name}}</text>
        <view class="feeder-rating">
          <text class="star">⭐</text>
          <text class="rating-num">{{item.rating}}</text>
        </view>
        <text class="feeder-count">服务 {{item.serviceCount}} 次</text>
        <text class="feeder-dorm">{{item.dormitory}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 底部占位 -->
  <view style="height: 120rpx;"></view>
</view>
