/* 消息页样式 */
.msg-tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #F5EDE5;
}

.msg-tab {
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #999;
  position: relative;
  margin-right: 10rpx;
}

.msg-tab.active {
  color: #FF8C42;
  font-weight: 600;
}

.msg-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #FF8C42;
  border-radius: 3rpx;
}

.tab-dot {
  position: absolute;
  top: 18rpx;
  right: 6rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FF4D4F;
}

.msg-list {
  padding: 10rpx 30rpx;
}

.msg-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F8F0E8;
}

.msg-item:last-child {
  border-bottom: none;
}

.msg-avatar-wrap {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.msg-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-avatar-icon {
  font-size: 36rpx;
}

.msg-unread-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #FF4D4F;
  border: 3rpx solid #FFF;
}

.msg-content {
  flex: 1;
  overflow: hidden;
}

.msg-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.msg-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.msg-time {
  font-size: 22rpx;
  color: #BBB;
}

.msg-preview {
  display: block;
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
